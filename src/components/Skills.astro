---
// Skills/Tech Stack section
---

<section class="skills">
  <div class="container">
    <h2 class="section-title">Skills & Expertise</h2>
    <p class="section-subtitle">Domains and technologies I work with</p>

    <div class="skills-grid">
      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"></path>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
            </svg>
          </div>
          <h3 class="category-title">Mathematics & Statistics</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">Mathematical Modelling</span>
          <span class="skill-tag">Statistical Analysis</span>
          <span class="skill-tag">Optimization</span>
          <span class="skill-tag">Probability Theory</span>
          <span class="skill-tag">Linear Algebra</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          </div>
          <h3 class="category-title">AI & Machine Learning</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">Deep Learning</span>
          <span class="skill-tag">NLP</span>
          <span class="skill-tag">Computer Vision</span>
          <span class="skill-tag">PyTorch</span>
          <span class="skill-tag">Transformers</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>
          <h3 class="category-title">Engineering & DevOps</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">Python</span>
          <span class="skill-tag">TypeScript</span>
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">CI/CD</span>
          <span class="skill-tag">Cloud Infrastructure</span>
          <span class="skill-tag">Git</span>
        </div>
      </div>

      <div class="skill-category learning-category">
        <div class="category-header">
          <div class="category-icon learning">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
          </div>
          <h3 class="category-title">Quantitative Finance</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag learning">Algorithmic Trading</span>
          <span class="skill-tag learning">Market Microstructure</span>
          <span class="skill-tag learning">Time Series Analysis</span>
          <span class="skill-tag learning">Risk Modelling</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 6rem 2rem;
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-dim);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .skill-category {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .skill-category:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 30px rgba(59, 130, 246, 0.15);
  }

  .learning-category:hover {
    border-color: var(--color-accent-purple);
    box-shadow: 0 8px 30px rgba(139, 92, 246, 0.15);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .category-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.1);
    border-radius: 0.5rem;
    color: var(--color-primary);
  }

  .category-icon.learning {
    background: rgba(139, 92, 246, 0.1);
    color: var(--color-accent-purple);
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    padding: 0.375rem 0.75rem;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    transition: all 0.2s ease;
  }

  .skill-tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .skill-tag.learning {
    background: rgba(139, 92, 246, 0.08);
    border-color: rgba(139, 92, 246, 0.3);
  }

  .skill-tag.learning:hover {
    border-color: var(--color-accent-purple);
    color: var(--color-accent-purple);
  }

  @media (max-width: 768px) {
    .skills {
      padding: 4rem 1.5rem;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
