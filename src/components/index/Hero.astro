---
import PageControls from "@/components/PageControls.astro";
import { homeContent, siteConfig } from "@/config/content";

interface Props {
  showControls?: boolean;
}

const { showControls = true } = Astro.props;
---

<div>
  <div class="flex justify-between items-start gap-4">
    <img
      class="rounded-full size-24 border border-hub-border dark:border-hub-border-dark dark:bg-hub-surface-dark hover:dark:bg-hub-surface-hover-dark object-cover transition-colors shrink-0"
      src={siteConfig.profileImage}
      alt={siteConfig.name}
    />
    {showControls && <PageControls />}
  </div>
  <div class="mt-4">
    <h1 class="font-medium text-2xl text-hub-title dark:text-hub-title-dark">
      {homeContent.title}
    </h1>
    <p class="text-base text-hub-subtitle dark:text-hub-subtitle-dark">
      {homeContent.subtitle}
    </p>
  </div>
</div>
