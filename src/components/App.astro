---
import SectionContainer from "./SectionContainer.astro";
import Hero from "./index/Hero.astro";
import SocialMedia from "./index/SocialMedia.astro";
import Navbar from "./Navbar.astro";
import Layout from "@/layouts/Layout.astro";
import { siteConfig } from "@/config/content";
---

<Layout title={siteConfig.title} description={siteConfig.description}>
  <main class="mx-6 mt-4 md:max-w-[1000px] md:w-full">
    <SectionContainer class="flex flex-col gap-y-6">
      <Hero />
      <SocialMedia />
    </SectionContainer>
    <SectionContainer class="">
      <Navbar />
    </SectionContainer>
  </main>
</Layout>
