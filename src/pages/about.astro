---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThreeBackground from '../components/ThreeBackground.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About - timothythchan" description="About timothythchan">
  <ThreeBackground />
  <Navigation />

  <main class="about-page">
    <div class="container">
      <h1 class="page-title">About Me</h1>

      <div class="content-grid">
        <section class="content-section intro-section">
          <h2>Hello, I'm Timothy</h2>
          <p>
            I'm a mathematician, statistician, and AI engineer passionate about applying
            rigorous mathematical thinking to real-world problems. My work sits at the
            intersection of pure mathematics, machine learning, and systems engineering.
          </p>
          <p>
            I build AI-powered systems that tackle inefficiencies across domains,
            and I use mathematical modelling to uncover dynamics in complex systems
            including financial markets. I'm dedicated to making mathematics more
            generalizable and interesting.
          </p>
        </section>

        <section class="content-section">
          <h2>What I Do</h2>
          <div class="what-i-do-grid">
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 20h9"></path>
                  <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                </svg>
              </div>
              <h3>Mathematical Research</h3>
              <p>Exploring mathematical theory and developing generalizable frameworks across domains.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
              </div>
              <h3>AI Engineering</h3>
              <p>Building AI-powered systems and machine learning pipelines that solve real problems.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                </svg>
              </div>
              <h3>Quantitative Analysis</h3>
              <p>Uncovering financial market dynamics with statistical rigor and algorithmic models.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
                  <rect x="9" y="9" width="6" height="6"></rect>
                  <line x1="9" y1="1" x2="9" y2="4"></line>
                  <line x1="15" y1="1" x2="15" y2="4"></line>
                  <line x1="9" y1="20" x2="9" y2="23"></line>
                  <line x1="15" y1="20" x2="15" y2="23"></line>
                  <line x1="20" y1="9" x2="23" y2="9"></line>
                  <line x1="20" y1="14" x2="23" y2="14"></line>
                  <line x1="1" y1="9" x2="4" y2="9"></line>
                  <line x1="1" y1="14" x2="4" y2="14"></line>
                </svg>
              </div>
              <h3>DevOps & Infrastructure</h3>
              <p>Designing and maintaining scalable infrastructure and deployment pipelines.</p>
            </div>
          </div>
        </section>

        <section class="content-section">
          <h2>My Approach</h2>
          <p>
            I approach every problem with mathematical rigor — whether it's building
            an AI system, analyzing market data, or designing an algorithm. I believe
            the best solutions come from first-principles thinking combined with
            practical engineering.
          </p>
          <p>
            My work spans from theoretical research to production systems, always with
            an emphasis on correctness, performance, and elegant design.
          </p>
        </section>

        <section class="content-section cta-section">
          <h2>Let's Connect</h2>
          <p>Interested in my work or want to collaborate on a project?</p>
          <div class="contact-buttons">
            <a href={`${base}projects/`} class="btn btn-primary">
              View My Work
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
            <a href={`${base}blog/`} class="btn btn-secondary">Read My Blog</a>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding: calc(var(--nav-height) + 2rem) 2rem 5rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-text);
  }

  .content-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-section {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
  }

  .content-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .content-section p {
    line-height: 1.7;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .content-section p:last-of-type {
    margin-bottom: 0;
  }

  .what-i-do-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .service-card {
    padding: 1.25rem;
    background: rgba(59, 130, 246, 0.05);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .service-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.1);
  }

  .service-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.1);
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .service-card h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .service-card p {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .cta-section {
    text-align: center;
  }

  .cta-section p {
    margin-bottom: 1.5rem;
  }

  .contact-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    text-decoration: none;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
  }

  .btn-primary:hover {
    background: #2563EB;
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5);
  }

  .btn-primary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .about-page {
      padding-top: calc(var(--nav-height) + 1rem);
    }

    .what-i-do-grid {
      grid-template-columns: 1fr;
    }

    .contact-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>
