---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Home" description="Timothy Chan – Software Engineer & Tech Enthusiast">
  <!-- Hero -->
  <section class="min-h-[calc(100vh-4rem)] flex items-center">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="animate-slide-up">
        <p class="font-mono text-brand text-sm uppercase tracking-widest mb-4">
          &gt; Hello, World!
        </p>
        <h1 class="text-5xl sm:text-7xl font-bold text-slate-100 leading-tight mb-6">
          I'm <span class="text-brand">Timothy</span><br />
          Chan
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl mb-10 leading-relaxed">
          Software Engineer passionate about building elegant, scalable solutions.
          I love exploring the intersection of technology and creativity.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/projects" class="btn-primary">
            View Projects
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/contact" class="btn-outline">Get in Touch</a>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-slate-600 text-xs font-mono animate-bounce">
        <span>scroll</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>
  </section>

  <!-- Skills / Tech Stack -->
  <section class="py-24 border-t border-surface-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="section-subheading">&gt; Tech Stack</p>
      <h2 class="section-heading">What I Work With</h2>
      <p class="text-slate-400 max-w-2xl mb-12">
        A curated set of tools and technologies I use to build and ship products.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {[
          { name: 'TypeScript', category: 'Language' },
          { name: 'Python', category: 'Language' },
          { name: 'React', category: 'Frontend' },
          { name: 'Astro', category: 'Frontend' },
          { name: 'Node.js', category: 'Backend' },
          { name: 'PostgreSQL', category: 'Database' },
          { name: 'Docker', category: 'DevOps' },
          { name: 'Git', category: 'Tooling' },
        ].map(tech => (
          <div class="card hover:border-brand/40 transition-colors duration-200">
            <p class="text-xs font-mono text-brand/60 mb-1">{tech.category}</p>
            <p class="font-semibold text-slate-200">{tech.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Posts Preview -->
  <section class="py-24 border-t border-surface-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="section-subheading">&gt; Latest Posts</p>
          <h2 class="section-heading">From the Blog</h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-2 text-brand font-mono text-sm hover:underline">
          All posts
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            title: 'Getting Started with Astro',
            excerpt: 'A quick-start guide to building fast, content-focused websites with the Astro framework.',
            date: 'Jan 2025',
            slug: 'getting-started-with-astro',
          },
          {
            title: 'TypeScript Best Practices',
            excerpt: 'Tips and patterns for writing clean, maintainable TypeScript code in real-world projects.',
            date: 'Feb 2025',
            slug: 'typescript-best-practices',
          },
          {
            title: 'My Developer Setup',
            excerpt: 'A walkthrough of the tools, apps, and hardware that make up my daily development workflow.',
            date: 'Mar 2025',
            slug: 'developer-setup',
          },
        ].map(post => (
          <a href={`/blog/${post.slug}`} class="card hover:border-brand/40 transition-colors duration-200 group flex flex-col">
            <p class="text-xs font-mono text-slate-500 mb-3">{post.date}</p>
            <h3 class="font-semibold text-slate-200 mb-2 group-hover:text-brand transition-colors">{post.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed flex-1">{post.excerpt}</p>
            <span class="mt-4 text-brand text-sm font-mono flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              Read more →
            </span>
          </a>
        ))}
      </div>

      <div class="mt-8 sm:hidden">
        <a href="/blog" class="btn-outline w-full justify-center">View all posts</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 border-t border-surface-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-subheading justify-center">&gt; Let's Connect</p>
      <h2 class="section-heading">Have a project in mind?</h2>
      <p class="text-slate-400 max-w-xl mx-auto mb-8">
        I'm always open to interesting conversations and new opportunities.
        Feel free to reach out!
      </p>
      <a href="/contact" class="btn-primary">
        Contact Me
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </a>
    </div>
  </section>
</PageLayout>
