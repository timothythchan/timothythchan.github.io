---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/index/Hero.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import PageControls from "@/components/PageControls.astro";
import { getPostBySlug, getAllPostSlugs } from "@/utils/getPosts";

export async function getStaticPaths() {
  const slugs = getAllPostSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/");
}

const post = getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/");
}

const { frontmatter, Content } = post;

if (!Content) {
  return Astro.redirect("/");
}

const dateStr = frontmatter.date || frontmatter.pubDate || "";
const formattedDate = dateStr
  ? new Date(dateStr).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
---

<Layout
  title={`${frontmatter.title} - Timothy Chan`}
  description={frontmatter.description || ""}
>
  <main class="mx-6 mt-4 md:max-w-[1000px] md:w-full pb-12">
    <div class="flex justify-end mb-4">
      <PageControls />
    </div>
    <SectionContainer class="flex flex-col gap-y-6">
      <Hero showControls={false} />
    </SectionContainer>

    <SectionContainer>
      <article>
        <header class="mb-8">
          <h1
            class="font-medium text-2xl text-hub-title dark:text-hub-title-dark"
          >
            {frontmatter.title}
          </h1>
          <div
            class="flex items-center gap-3 mt-2 text-xs text-hub-subtitle dark:text-hub-subtitle-dark"
          >
            {
              formattedDate && (
                <time datetime={dateStr}>{formattedDate}</time>
              )
            }
            <span>•</span>
            <span>{frontmatter.readTime || "5 min read"}</span>
          </div>
          {
            frontmatter.description && (
              <p class="mt-4 text-sm text-hub-subtitle dark:text-hub-subtitle-dark">
                {frontmatter.description}
              </p>
            )
          }
        </header>

        <div
          class="prose prose-sm prose-neutral dark:prose-invert max-w-none prose-headings:text-hub-title dark:prose-headings:text-hub-title-dark prose-p:text-hub-subtitle dark:prose-p:text-hub-subtitle-dark"
        >
          <Content />
        </div>
      </article>
    </SectionContainer>
  </main>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const proseContainer = document.querySelector(".prose");
    if (proseContainer) {
      const firstH1 = proseContainer.querySelector("h1");
      if (firstH1) {
        firstH1.remove();
      }
    }
  });
</script>
