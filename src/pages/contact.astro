---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Contact" description="Get in touch with Timothy Chan – software engineer and tech enthusiast.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <!-- Header -->
    <div class="mb-16 animate-slide-up">
      <p class="section-subheading">&gt; Contact</p>
      <h1 class="section-heading text-5xl">Get in Touch</h1>
      <p class="text-slate-400 max-w-2xl mt-4">
        Have a question, a project idea, or just want to chat about tech?
        I'd love to hear from you. Fill out the form below or reach me directly.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div>
        <form
          id="contact-form"
          class="space-y-6"
          netlify
          name="contact"
          method="POST"
        >
          <input type="hidden" name="form-name" value="contact" />

          <div>
            <label for="name" class="block text-sm font-mono text-slate-300 mb-2">
              Name <span class="text-brand">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Your name"
              class="w-full px-4 py-3 bg-surface-card border border-surface-border rounded-lg text-slate-100 placeholder-slate-500 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-mono text-slate-300 mb-2">
              Email <span class="text-brand">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="your@email.com"
              class="w-full px-4 py-3 bg-surface-card border border-surface-border rounded-lg text-slate-100 placeholder-slate-500 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-mono text-slate-300 mb-2">
              Subject
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="What's this about?"
              class="w-full px-4 py-3 bg-surface-card border border-surface-border rounded-lg text-slate-100 placeholder-slate-500 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-mono text-slate-300 mb-2">
              Message <span class="text-brand">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="Your message..."
              class="w-full px-4 py-3 bg-surface-card border border-surface-border rounded-lg text-slate-100 placeholder-slate-500 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors resize-none"
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center">
            Send Message
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>

          <p id="form-status" class="text-center text-sm font-mono hidden"></p>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="space-y-6">
        <div class="card">
          <h3 class="font-semibold text-slate-100 mb-6">Other Ways to Connect</h3>
          <div class="space-y-4">
            {[
              {
                label: 'Email',
                value: 'hello@timothythchan.com',
                href: 'mailto:hello@timothythchan.com',
                icon: 'email',
              },
              {
                label: 'GitHub',
                value: 'github.com/timothythchan',
                href: 'https://github.com/timothythchan',
                icon: 'github',
              },
              {
                label: 'LinkedIn',
                value: 'linkedin.com/in/timothythchan',
                href: 'https://linkedin.com/in/timothythchan',
                icon: 'linkedin',
              },
            ].map(item => (
              <a
                href={item.href}
                target={item.href.startsWith('mailto') ? '_self' : '_blank'}
                rel="noopener noreferrer"
                class="flex items-center gap-4 text-slate-400 hover:text-brand transition-colors group"
              >
                <div class="w-10 h-10 bg-brand/10 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-brand/20 transition-colors">
                  {item.icon === 'email' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  )}
                  {item.icon === 'github' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                  )}
                  {item.icon === 'linkedin' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  )}
                </div>
                <div>
                  <p class="text-xs font-mono text-slate-500 mb-0.5">{item.label}</p>
                  <p class="text-sm">{item.value}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="card">
          <h3 class="font-semibold text-slate-100 mb-3">Response Time</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            I typically respond within <span class="text-brand">1–2 business days</span>.
            For urgent matters, LinkedIn is the fastest way to reach me.
          </p>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status) return;

    const data = new FormData(form);
    try {
      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(
          Array.from(data.entries()).flatMap(([k, v]) =>
            typeof v === 'string' ? [[k, v]] : []
          )
        ).toString(),
      });

      if (response.ok) {
        status.textContent = '✓ Message sent! I\'ll get back to you soon.';
        status.className = 'text-center text-sm font-mono text-green-400';
        form.reset();
      } else {
        throw new Error('Network response was not ok');
      }
    } catch {
      status.textContent = '✗ Something went wrong. Please try again or email me directly.';
      status.className = 'text-center text-sm font-mono text-red-400';
    }
    status.classList.remove('hidden');
  });
</script>
